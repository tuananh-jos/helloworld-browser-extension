<Page
    x:Class="uwp_app.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:uwp_app"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel Padding="24" Spacing="12">
        <TextBlock Text="Hello Password UWP" FontSize="28" FontWeight="Bold"/>
        <TextBlock Text="App Service: com.hellopassword.appservice"
                   FontSize="13" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        <TextBlock Text="Waiting for messages from browser extension via native host..."
                   FontSize="13" Foreground="Gray"/>
        <Border BorderThickness="1"
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                CornerRadius="4" Padding="8">
            <ListView x:Name="LogList" Height="360" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="13"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
        <Button Content="Clear" Click="OnClearClick" HorizontalAlignment="Left"/>
    </StackPanel>
</Page>
