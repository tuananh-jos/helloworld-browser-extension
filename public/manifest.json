{
  "manifest_version": 3,
  "name": "Hello Password",
  "version": "1.0.0",
  "description": "A simple Hello World password manager extension",
  "action": {
    "default_popup": "index.html",
    "default_title": "Hello Password"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "favicon.ico",
    "48": "logo192.png",
    "128": "logo512.png"
  }
}
